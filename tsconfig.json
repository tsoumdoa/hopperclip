{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"types": ["vite/client"],
		"baseUrl": ".",
		"paths": {
			"@convex/*": ["convex/*"],
			"@/*": ["src/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", "src", "convex"],
	"exclude": ["node_modules", ".output", "dist"]
}
