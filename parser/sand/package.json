{
  "name": "gh-parser",
  "version": "1.0.0",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "parse": "bun run src/parse.ts",
    "dev": "bun --watch run src/parse.ts",
    "batch": "bun run src/batch-parse.ts \"xmls/*.xml\"",
    "batch-visuals": "bun run src/batch-parse.ts --visuals \"xmls/*.xml\""
  },
  "type": "module",
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "glob": "^13.0.6"
  }
}
